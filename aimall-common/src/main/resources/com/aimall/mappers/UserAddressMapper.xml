<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aimall.mappers.UserAddressMapper">

	<!--瀹炰綋鏄犲皠-->
	<resultMap id="base_result_map" type="com.aimall.entity.po.UserAddress">
		<!--鍦板潃ID-->
		<result column="address_id" property="addressId"  />
		<!--鐢ㄦ埛ID-->
		<result column="user_id" property="userId"  />
		<!--璇︾粏鍦板潃-->
		<result column="address" property="address"  />
		<!--鏀惰揣浜?->
		<result column="addressee" property="addressee"  />
		<!--鎵嬫満鍙风爜-->
		<result column="phone" property="phone"  />
		<!--榛樿绫诲瀷0:闈為粯璁? 1:榛樿-->
		<result column="default_type" property="defaultType"  />
	</resultMap>


	<!-- 閫氱敤鏌ヨ缁撴灉鍒?->
	<sql id="base_column_list">
		 u.address_id,u.user_id,u.address,u.addressee,u.phone,
		 u.default_type
	</sql>

	<sql id="base_condition_filed">
			<if test="query.addressId != null and query.addressId!=''">
				 and  u.address_id = #{query.addressId}
			</if>
			<if test="query.userId != null and query.userId!=''">
				 and  u.user_id = #{query.userId}
			</if>
			<if test="query.address != null and query.address!=''">
				 and  u.address = #{query.address}
			</if>
			<if test="query.addressee != null and query.addressee!=''">
				 and  u.addressee = #{query.addressee}
			</if>
			<if test="query.phone != null and query.phone!=''">
				 and  u.phone = #{query.phone}
			</if>
			<if test="query.defaultType != null">
				 and  u.default_type = #{query.defaultType}
			</if>
	</sql>

	<!-- 閫氱敤鏌ヨ鏉′欢鍒?->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.addressIdFuzzy!= null  and query.addressIdFuzzy!=''">
				 and  u.address_id like concat('%', #{query.addressIdFuzzy}, '%')
			</if>
			<if test="query.userIdFuzzy!= null  and query.userIdFuzzy!=''">
				 and  u.user_id like concat('%', #{query.userIdFuzzy}, '%')
			</if>
			<if test="query.addressFuzzy!= null  and query.addressFuzzy!=''">
				 and  u.address like concat('%', #{query.addressFuzzy}, '%')
			</if>
			<if test="query.addresseeFuzzy!= null  and query.addresseeFuzzy!=''">
				 and  u.addressee like concat('%', #{query.addresseeFuzzy}, '%')
			</if>
			<if test="query.phoneFuzzy!= null  and query.phoneFuzzy!=''">
				 and  u.phone like concat('%', #{query.phoneFuzzy}, '%')
			</if>
	 </where>
	</sql>

	<!-- 鏌ヨ闆嗗悎-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM user_address u <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 鏌ヨ鏁伴噺-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM user_address u <include refid="query_condition" />
	</select>

	<!-- 鎻掑叆 锛堝尮閰嶆湁鍊肩殑瀛楁锛?->
	<insert id="insert" parameterType="com.aimall.entity.po.UserAddress">
		 INSERT INTO user_address
		 <trim prefix="(" suffix=")" suffixOverrides="," >
			<if test="bean.addressId != null">
				 address_id,
			</if>
			<if test="bean.userId != null">
				 user_id,
			</if>
			<if test="bean.address != null">
				 address,
			</if>
			<if test="bean.addressee != null">
				 addressee,
			</if>
			<if test="bean.phone != null">
				 phone,
			</if>
			<if test="bean.defaultType != null">
				 default_type,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.addressId!=null">
				 #{bean.addressId},
			</if>
			<if test="bean.userId!=null">
				 #{bean.userId},
			</if>
			<if test="bean.address!=null">
				 #{bean.address},
			</if>
			<if test="bean.addressee!=null">
				 #{bean.addressee},
			</if>
			<if test="bean.phone!=null">
				 #{bean.phone},
			</if>
			<if test="bean.defaultType!=null">
