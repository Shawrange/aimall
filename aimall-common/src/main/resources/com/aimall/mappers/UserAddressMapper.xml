	</delete>

	<!-- 鏍规嵁PrimaryKey鑾峰彇瀵硅薄-->
	<select id="selectByAddressId" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from user_address u where address_id=#{addressId}
	</select>

